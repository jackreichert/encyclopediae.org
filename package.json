{
    "name": "encyclopediae",
    "version": "1.0.0",
    "private": true,
    "description": "Decentralized academic knowledge project",
    "scripts": {
        "sass": "sass styles.scss:styles.css --watch",
        "sass:build": "sass styles.scss:styles.css --style compressed",
        "site:build": "eleventy",
        "site:serve": "eleventy --serve",
        "build": "npm run sass:build && npm run site:build",
        "start": "npm run sass",
        "deploy:signup": "set -a && [ -f .env ] && . ./.env && set +a && npx wrangler deploy --env signup",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,html}\"",
        "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,html}\"",
        "cleanup": "bun run format && bun run lint:fix"
    },
    "devDependencies": {
        "@11ty/eleventy": "^3.1.6",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.6.0",
        "prettier": "^3.4.2",
        "sass": "^1.69.5"
    },
    "dependencies": {
        "google-spreadsheet": "^4.1.4"
    }
}
